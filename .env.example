# ============================================================
# Multimodal AI Intelligence Platform — env template.
# Copy to `.env` (gitignored) and fill in. For prod, override
# every value tagged "CHANGE IN PROD" below.
# ============================================================

# ---------- App ----------
APP_ENV=development            # CHANGE IN PROD: production
APP_DEBUG=true                 # CHANGE IN PROD: false

# ---------- Backend ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated allow-list. CHANGE IN PROD to your real origin(s):
#   BACKEND_CORS_ORIGINS=https://app.example.com
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---------- Auth / JWT ----------
# CHANGE IN PROD: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------- Postgres ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=mmap
POSTGRES_PASSWORD=mmap_dev_password   # CHANGE IN PROD
POSTGRES_DB=mmap
# Managed Postgres (Neon, Supabase, etc.): postgresql+asyncpg://...?ssl=require
# DATABASE_URL=

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
# Managed Redis (Upstash, Redis Cloud):
# REDIS_PASSWORD=
# REDIS_SECURE=false                  # true for rediss://

# ---------- Qdrant ----------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
# Qdrant Cloud:
# QDRANT_URL=https://CLUSTER.aws.cloud.qdrant.io
# QDRANT_API_KEY=

# ---------- Neo4j ----------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_dev_password     # CHANGE IN PROD

# ---------- MinIO ----------
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin            # CHANGE IN PROD
MINIO_ROOT_PASSWORD=minioadmin_dev    # CHANGE IN PROD
MINIO_BUCKET=mmap-uploads
MINIO_SECURE=false                    # CHANGE IN PROD: true if behind TLS

# ---------- AI Providers ----------
OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
OPENROUTER_REASONING_MODEL=deepseek/deepseek-v4-flash:free

GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GROQ_REASONING_MODEL=openai/gpt-oss-120b
GROQ_EXTRACTION_MODEL=openai/gpt-oss-120b

# ---------- Observability ----------
# In prod, point at your collector (Jaeger / Tempo / Honeycomb / Datadog).
OTEL_ENABLED=true
OTEL_SERVICE_NAME=mmap-backend
OTEL_ENDPOINT=http://jaeger:4317

# ---------- Security ----------
# Per-IP rate limits on /auth/*. CI test runs flip this off to keep counters
# from leaking across tests.
RATE_LIMIT_ENABLED=true

# ---------- Frontend ----------
# CHANGE IN PROD to the public URL the browser will see:
#   NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# PostHog product analytics. Leave the key empty in dev/CI to disable the
# client SDK entirely; in prod set the project key from app.posthog.com.
# Host is the US instance by default; switch to https://eu.i.posthog.com if
# your project lives on PostHog EU.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---------- Docker socket (Traefik) ----------
# macOS (Docker Desktop): ${HOME}/.docker/run/docker.sock
# Linux:                  /var/run/docker.sock
DOCKER_SOCK=/var/run/docker.sock

# ---------- Tavily ----------
TAVILY_API_KEY=
