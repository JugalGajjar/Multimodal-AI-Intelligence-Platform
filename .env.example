# ============================================================
# Multimodal AI Intelligence Platform — root env example
# Copy to `.env` and fill in. Do NOT commit `.env`.
# ============================================================

# ---------- App ----------
APP_ENV=development
APP_DEBUG=true

# ---------- Backend ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---------- Auth / JWT ----------
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------- Postgres ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=mmap
POSTGRES_PASSWORD=mmap_dev_password
POSTGRES_DB=mmap

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379

# ---------- Qdrant ----------
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ---------- Neo4j ----------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_dev_password

# ---------- MinIO ----------
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev
MINIO_BUCKET=mmap-uploads
MINIO_SECURE=false

# ---------- AI Providers ----------
OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=qwen/qwen2.5-vl-72b-instruct:free
OPENROUTER_REASONING_MODEL=deepseek/deepseek-r1:free

GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------- Docker socket (Traefik) ----------
# macOS (Docker Desktop): ${HOME}/.docker/run/docker.sock
# Linux:                  /var/run/docker.sock
DOCKER_SOCK=/var/run/docker.sock
